FROM apache/airflow:3.3.0

USER root
RUN apt-get update \
    && apt-get install -y --no-install-recommends docker.io \
    && rm -rf /var/lib/apt/lists/*
USER airflow

# dbt внутри Airflow — нужно Cosmos для режима LOCAL.
# Те же пины, что и раньше: dbt-core<1.10, чтобы не тянуть wheel с GitHub.
RUN pip install --no-cache-dir \
    "astronomer-cosmos>=1.11" \
    "dbt-postgres==1.9.0" "dbt-core>=1.9,<1.10"